# logistics-gateway — example environment
# Copy to .env and fill in. Never commit .env.

# --- Node ---
NODE_ENV=development
GATEWAY_PORT=8080
LOG_LEVEL=info
LOG_SERVICE_NAME=logistics-gateway

# --- Secrets (32+ chars; JWT_SECRET and SERVICE_JWT_SECRET MUST be different) ---
JWT_SECRET=replace-me-32-chars-or-more-aaaaaaaaaaaaaaaaaaaa
SERVICE_JWT_SECRET=replace-me-DIFFERENT-32-chars-bbbbbbbbbbbbbbbbbbb

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Upstream services (Phase 2 required: auth + user. Phase 3+ optional.) ---
AUTH_SERVICE_URL=http://localhost:8081
USER_SERVICE_URL=http://localhost:8082
# ORDER_SERVICE_URL=
# DISPATCH_SERVICE_URL=
TRACKING_SERVICE_URL=http://localhost:3005
NOTIFICATION_SERVICE_URL=http://localhost:3006
# AI_SERVICE_URL=

# --- CORS (comma-separated; no wildcard, no trailing slash) ---
GATEWAY_CORS_ORIGINS=http://localhost:3000

# --- Tunables (sensible defaults; override only if needed) ---
GATEWAY_PROXY_TIMEOUT_MS=10000
GATEWAY_RETRY_DELAY_MS=250
GATEWAY_ANON_RPM=60
GATEWAY_AUTH_RPM=300
GATEWAY_RATE_LIMIT_WINDOW_MS=60000
GATEWAY_SHUTDOWN_GRACE_MS=10000
